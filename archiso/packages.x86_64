konsole               # Gelişmiş Yeni Nesil Terminal
kamoso                # Kamera Uygulaması
systemsettings        # Gelişmiş Ayarlar Menüsü

# --- Sistem Araçları ve İnternet
git
wget
nano
firefox               # Varsayılan İnternet Tarayıcısı
